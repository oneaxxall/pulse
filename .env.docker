## Config mysql
## docker run -p 6001:6001 --add-host=host.docker.internal:host-gateway pulse

## Enable Debug
PULSE_DEBUG=0

PULSE_MANAGER_DRIVER=mysql
PULSE_DB_MYSQL_HOST=host.docker.internal
PULSE_DB_MYSQL_PORT=3306
PULSE_DB_MYSQL_USERNAME=root
PULSE_DB_MYSQL_PASSWORD=1234
PULSE_DB_MYSQL_DATABASE=pulsemanager
PULSE_MANAGER_MYSQL_TABLE=pulse_manager
PULSE_MANAGER_MYSQL_VERSION=5.6