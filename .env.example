# =============================================================================
# PDS PUSHER SERVER - Environment Configuration
# =============================================================================
# This file defines all configurable environment variables for the PDS Pusher
# Server. Uncomment and set the values you need. Defaults are defined in the
# server's source code (src/server.ts).
# =============================================================================

# =============================================================================
# GENERAL CONFIGURATION
# =============================================================================
# Core server settings: debug mode, adapter driver, operating mode, port, etc.

PULSE_DEBUG=1
#PULSE_ADAPTER_DRIVER=local      # Options: local, redis, nats, cluster
#PULSE_MODE=full                 # Options: full, server, worker
#PULSE_PORT=6001                 # The port the WebSocket server listens on
#PULSE_PATH_PREFIX=              # URL path prefix for all endpoints
#PULSE_HOST=0.0.0.0              # The host address to bind the server to

# =============================================================================
# APP MANAGER CONFIGURATION
# =============================================================================
# Configure the app manager driver and default application credentials.
# The app manager stores and retrieves app configuration data (credentials,
# limits, webhooks, etc.). Supports array (in-memory), MySQL, and PostgreSQL.

#PULSE_MANAGER_DRIVER=array      # Options: array, mysql, postgres
#PULSE_DEFAULT_MANAGER_ID=app-id           # Default app ID for the array driver
#PULSE_DEFAULT_MANAGER_KEY=app-key         # Default app key for the array driver
#PULSE_DEFAULT_MANAGER_SECRET=app-secret   # Default app secret for the array driver
#PULSE_DEFAULT_MANAGER_MAX_CONNS=-1        # Max concurrent connections per app (-1 = unlimited)
#PULSE_DEFAULT_MANAGER_ENABLE_CLIENT_MESSAGES=false  # Allow client-to-client events
#PULSE_DEFAULT_MANAGER_ENABLED=true        # Whether the app is active
#PULSE_DEFAULT_MANAGER_MAX_BACKEND_EVENTS_PER_SEC=-1  # Rate limit for POST /events
#PULSE_DEFAULT_MANAGER_MAX_CLIENT_EVENTS_PER_SEC=-1   # Rate limit for client events per socket
#PULSE_DEFAULT_MANAGER_MAX_READ_REQ_PER_SEC=-1        # Rate limit for read API endpoints
#PULSE_DEFAULT_MANAGER_WEBHOOKS=[]         # JSON array of webhook configurations
#PULSE_DEFAULT_MANAGER_USER_AUTHENTICATION=false     # Enable user authentication endpoint

# -- App Manager Cache --
# Cache app lookups in memory or Redis to reduce database queries.
#PULSE_MANAGER_CACHE_ENABLED=false
#PULSE_MANAGER_CACHE_TTL=-1                # Cache TTL in seconds (-1 = no expiry)

# =============================================================================
# MYSQL DATABASE CONFIGURATION
# =============================================================================
# Required when PULSE_MANAGER_DRIVER=mysql.
# Connection details for the MySQL database that stores app configurations.

#PULSE_DB_MYSQL_HOST=127.0.0.1
#PULSE_DB_MYSQL_PORT=3306
#PULSE_DB_MYSQL_USERNAME=root
#PULSE_DB_MYSQL_PASSWORD=password
#PULSE_DB_MYSQL_DATABASE=main
#PULSE_MANAGER_MYSQL_TABLE=pds-pusher-manager
#PULSE_MANAGER_MYSQL_VERSION=8.0
#PULSE_MANAGER_MYSQL_USE_V2=

# =============================================================================
# POSTGRESQL DATABASE CONFIGURATION
# =============================================================================
# Required when PULSE_MANAGER_DRIVER=postgres.
# Connection details for the PostgreSQL database that stores app configurations.

#PULSE_DB_POSTGRES_HOST=127.0.0.1
#PULSE_DB_POSTGRES_PORT=5432
#PULSE_DB_POSTGRES_USERNAME=postgres
#PULSE_DB_POSTGRES_PASSWORD=password
#PULSE_DB_POSTGRES_DATABASE=main
#PULSE_MANAGER_POSTGRES_TABLE=pds-pusher-manager
#PULSE_MANAGER_POSTGRES_VERSION=13.3

# =============================================================================
# DATABASE CONNECTION POOLING
# =============================================================================
# Enable and configure Knex connection pooling for MySQL/PostgreSQL connections.

#PULSE_DB_POOLING_ENABLED=false            # true | false
#PULSE_DB_POOLING_MIN=0                    # Minimum pool size
#PULSE_DB_POOLING_MAX=7                    # Maximum pool size

# =============================================================================
# SSL/TLS CONFIGURATION (WSS)
# =============================================================================
# Paths to SSL certificate files. Required if you want to serve secure
# WebSocket connections (WSS) over HTTPS.

#PULSE_SSL_CERT=                           # Path to SSL certificate file
#PULSE_SSL_KEY=                            # Path to SSL private key file
#PULSE_SSL_PASS=                           # Passphrase for the SSL key (if any)
#PULSE_SSL_CA=                             # Path to SSL certificate authority file

# =============================================================================
# REDIS DATABASE CONFIGURATION
# =============================================================================
# Redis is used for adapters, rate limiting, caching, and queue drivers.
# These settings define the base Redis connection.

#PULSE_DB_REDIS_HOST=127.0.0.1
#PULSE_DB_REDIS_PORT=6379
#PULSE_DB_REDIS_DB=0
#PULSE_DB_REDIS_USERNAME=null
#PULSE_DB_REDIS_PASSWORD=null
#PULSE_DB_REDIS_KEY_PREFIX=

# -- Redis Sentinel Configuration --
# Required when using Redis Sentinel for high availability.
#PULSE_DB_REDIS_SENTINELS=null             # JSON array: ["host:port", ...]
#PULSE_DB_REDIS_SENTINEL_PASSWORD=null
#PULSE_DB_REDIS_INSTANCE_NAME=mymaster

# -- Redis Cluster Configuration --
# Required when using Redis Cluster mode.
#PULSE_DB_REDIS_CLUSTER_NODES=             # JSON array: ["host:port", ...]

# =============================================================================
# ADAPTER CONFIGURATION
# =============================================================================
# The adapter manages WebSocket connection storage and cross-instance
# communication. Choose between local (single-process), Redis (multi-node),
# NATS (multi-node), or Cluster (multi-thread/same network).

# -- Adapter: Redis --
#PULSE_ADAPTER_REDIS_PREFIX=               # Key prefix for Redis adapter keys
#PULSE_ADAPTER_REDIS_CLUSTER_MODE=false    # Enable Redis cluster mode
#PULSE_ADAPTER_REDIS_REQUESTS_TIMEOUT=5000 # Timeout in ms for inter-instance requests
#PULSE_ADAPTER_REDIS_SUB_OPTIONS=           # JSON options for Redis subscriber
#PULSE_ADAPTER_REDIS_PUB_OPTIONS=           # JSON options for Redis publisher

# -- Adapter: Cluster --
#PULSE_ADAPTER_CLUSTER_REQUESTS_TIMEOUT=5000  # Timeout in ms for cluster requests

# -- Adapter: NATS --
# NATS is a lightweight messaging system for multi-node horizontal scaling.
#PULSE_ADAPTER_NATS_PREFIX=                # Key prefix for NATS subjects
#PULSE_ADAPTER_NATS_SERVERS='["127.0.0.1:4222"]'  # JSON array of NATS server addresses
#PULSE_ADAPTER_NATS_USER=null
#PULSE_ADAPTER_NATS_PASSWORD=null
#PULSE_ADAPTER_NATS_TOKEN=null
#PULSE_ADAPTER_NATS_TIMEOUT=10000          # Connection timeout in ms
#PULSE_ADAPTER_NATS_REQUESTS_TIMEOUT=10000 # Timeout in ms for NATS requests
#PULSE_ADAPTER_NATS_NODES_NUMBER=5000      # Expected number of NATS nodes

# =============================================================================
# CLUSTER / PRIVATE NETWORK CONFIGURATION
# =============================================================================
# This uses node-discover for auto-discovery of nodes on the same private
# network. Useful for multi-instance deployments without an external broker.

#PULSE_CLUSTER_HOST=0.0.0.0
#PULSE_CLUSTER_PORT=11002
#PULSE_CLUSTER_CHECK_INTERVAL=500          # How often to check peers (ms)
#PULSE_CLUSTER_HELLO_INTERVAL=500          # How often to broadcast presence (ms)
#PULSE_CLUSTER_MASTER_TIMEOUT=2000         # Timeout before master re-election (ms)
#PULSE_CLUSTER_NODE_TIMEOUT=2000           # Timeout before marking node as dead (ms)
#PULSE_CLUSTER_BROADCAST_ADDRESS=255.255.255.255
#PULSE_CLUSTER_MULTICAST_ADDRESS=null
#PULSE_CLUSTER_UNICAST_ADDRESSES=          # JSON array of specific peer addresses
#PULSE_CLUSTER_IGNORE_PROCESS=null
#PULSE_CLUSTER_PREFIX=                     # Key prefix for cluster data

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
# Rate limiting prevents abuse by controlling how many events a client or
# backend can send per second.
#
# Driver options:
#   local   - In-memory (lost on restart). Best for single-node single-thread.
#   redis   - Centralized via Redis. Best for multi-node deployments.
#   cluster - Centralized via elected master. Best for multi-thread (PM2).

#PULSE_RATE_LIMITER_DRIVER=local           # Options: local, redis, cluster
#PULSE_RATE_LIMITER_REDIS_CLUSTER_MODE=false
#PULSE_RATE_LIMITER_REDIS_OPTIONS=         # JSON options for Redis rate limiter

# =============================================================================
# EVENTS & CHANNELS LIMITS
# =============================================================================
# Constraints on event payloads, channel names, and batch sizes to prevent
# resource exhaustion.

#PULSE_HTTP_MAX_REQUEST_SIZE=100           # Max HTTP request body size in MB
#PULSE_EVENT_MAX_CHANNELS_AT_ONCE=100      # Max channels per event trigger
#PULSE_EVENT_MAX_NAME_LENGTH=200           # Max event name length in characters
#PULSE_EVENT_MAX_SIZE_IN_KB=100            # Max event payload size in KB
#PULSE_EVENT_MAX_BATCH_SIZE=10             # Max events per batch
#PULSE_CHANNEL_LIMITS_MAX_NAME_LENGTH=200  # Max channel name length in characters
#PULSE_CHANNEL_CACHE_TTL=3600              # Channel existence cache TTL in seconds

# =============================================================================
# PRESENCE CHANNEL CONFIGURATION
# =============================================================================
# Presence channels track connected users and their info.

#PULSE_PRESENCE_MAX_MEMBERS=100            # Max members per presence channel
#PULSE_PRESENCE_MAX_MEMBER_SIZE=2          # Max member metadata size in KB

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Cache driver for app lookups and other cached data.

#PULSE_CACHE_DRIVER=memory                 # Options: memory, redis
#PULSE_CACHE_REDIS_CLUSTER_MODE=false
#PULSE_CACHE_REDIS_OPTIONS=                # JSON options for Redis cache

# =============================================================================
# HTTP API CONFIGURATION
# =============================================================================
# Settings for the HTTP REST API (health, usage, event triggers).

#PULSE_HTTP_ACCEPT_TRAFFIC_MEMORY_THRESHOLD=75  # Max memory % before rejecting traffic

# =============================================================================
# METRICS CONFIGURATION (PROMETHEUS)
# =============================================================================
# Expose Prometheus metrics on a dedicated HTTP endpoint for monitoring.

#PULSE_METRICS_ENABLED=false
#PULSE_METRICS_DRIVER=prometheus
#PULSE_METRICS_HOST=0.0.0.0
#PULSE_METRICS_PROMETHEUS_PREFIX=pulse_
#PULSE_METRICS_SERVER_PORT=9601

# =============================================================================
# QUEUE CONFIGURATION
# =============================================================================
# The queue processes webhook deliveries and other async tasks.
#   sync  - Process synchronously (no external dependency)
#   redis - Process via BullMQ (Redis) for better reliability

#PULSE_QUEUE_DRIVER=sync                   # Options: sync, redis
#PULSE_QUEUE_REDIS_CONCURRENCY=1           # Number of concurrent jobs
#PULSE_QUEUE_REDIS_OPTIONS=                # JSON options for BullMQ Redis connection
#PULSE_QUEUE_REDIS_CLUSTER_MODE=false

# =============================================================================
# GRACEFUL SHUTDOWN & AUTHENTICATION
# =============================================================================
# Controls how the server shuts down and how long user authentication takes.

#PULSE_SHUTDOWN_GRACE_PERIOD=10000         # Time in ms to drain connections before exit
#PULSE_USER_AUTHENTICATION_TIMEOUT=30000   # Max time in ms for user auth to complete

# =============================================================================
# WEBHOOK CONFIGURATION
# =============================================================================
# Webhooks notify external services about events happening on channels.
# Batching groups multiple events into fewer HTTP requests.

#PULSE_WEBHOOKS_BATCHING_ENABLED=false     # Enable webhook event batching
#PULSE_WEBHOOKS_BATCHING_DURATION=50       # Batching window in ms

# =============================================================================
# WEBHOOK LOGS CONFIGURATION
# =============================================================================
# Persist webhook delivery logs to files or database for auditing.

#PULSE_WEBHOOKS_LOGS_ENABLED=false         # Log webhook deliveries to daily log files
#PULSE_WEBHOOKS_LOGS_DIR=logs              # Directory for log files (relative to cwd)
#                                                # Rotated daily: webhook-YYYY-MM-DD.log
#PULSE_WEBHOOKS_LOGS_DB_ENABLED=false      # Log webhook deliveries to database
#                                                # Works only with mysql/postgres manager driver
#                                                # Run SQL in configurations/pds-pusher-manager.sql

# =============================================================================
# RECOMMENDED SETTINGS REFERENCE
# =============================================================================
# Use Case                                | Adapter Driver      | Rate Limiter Driver
# ----------------------------------------|---------------------|--------------------
# Single node, one thread                 | local               | local
# Single node, multiple threads (PM2)     | cluster             | cluster
# Multi-node, one thread, same network    | cluster / redis     | cluster / redis
# Multi-node, multiple threads (PM2),
#   same private network                  | cluster / redis     | cluster / redis
# Multi-node, one thread, multi-network   | redis               | redis
# Multi-node, multiple threads (PM2),
#   multi-network                         | redis               | redis
#
# ℹ️ It is highly recommended to use single-thread choices in multi-node
#   architectures and scale horizontally at the instance level rather than
#   combining both instances and threads.